#!/usr/bin/env bash
# install — lifecycle hook run by `voodu plugins:install redis`.
#
# Responsibilities:
#   1. Download the voodu-redis plugin binary into
#      $VOODU_PLUGIN_DIR/bin/voodu-redis
#   2. (Nothing else — redis instances are spawned per redis-block
#      manifest by the statefulset reconciler. This plugin owns the
#      block expansion contract; runtime containers are voodu's
#      statefulset, not this plugin's.)
#
# Idempotent: safe to run repeatedly.

set -euo pipefail

PLUGIN_DIR="${VOODU_PLUGIN_DIR:-$(cd "$(dirname "$0")" && pwd)}"
PLUGIN_BIN="$PLUGIN_DIR/bin/voodu-redis"
RELEASE_REPO="${VOODU_REDIS_RELEASE_REPO:-thadeu/voodu-redis}"

log() { printf '[voodu-redis/install] %s\n' "$*"; }

arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) echo "unsupported arch: $(uname -m)" >&2; exit 1 ;;
  esac
}

install_voodu_redis() {
  local version
  version="$(grep '^version:' "$PLUGIN_DIR/plugin.yml" | awk '{print $2}')"

  if [ -z "$version" ]; then
    log "could not read version from $PLUGIN_DIR/plugin.yml" >&2
    exit 1
  fi

  if [ -x "$PLUGIN_BIN" ] && "$PLUGIN_BIN" --version 2>/dev/null | grep -q "$version"; then
    log "voodu-redis v$version already installed at $PLUGIN_BIN"
    return
  fi

  local a
  a="$(arch)"

  local url="https://github.com/${RELEASE_REPO}/releases/download/v${version}/voodu-redis_linux_${a}"

  log "downloading voodu-redis v$version ($a) from $url"

  mkdir -p "$(dirname "$PLUGIN_BIN")"

  local tmp
  tmp="$(mktemp)"

  if ! curl -fsSL "$url" -o "$tmp"; then
    rm -f "$tmp"
    log "failed to download voodu-redis binary from $url" >&2
    exit 1
  fi

  install -m 0755 "$tmp" "$PLUGIN_BIN"
  rm -f "$tmp"

  log "installed $PLUGIN_BIN"
}

main() {
  if [ "$(id -u)" -ne 0 ]; then
    log "this script must run as root (invoked by controller via plugins:install)"
    exit 1
  fi

  if ! command -v curl >/dev/null 2>&1; then
    log "curl is required but not found on PATH" >&2
    exit 1
  fi

  install_voodu_redis
}

main "$@"
