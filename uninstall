#!/usr/bin/env bash
# uninstall — lifecycle hook run by `voodu plugins:remove redis`.
#
# Drops the voodu-redis binary. Redis statefulsets the operator
# created remain — they're owned by voodu's statefulset kind, not
# this plugin. To wipe a redis instance:
#
#   vd delete statefulset/<scope>/<name> --prune
#
# Idempotent: missing binary is fine.

set -euo pipefail

PLUGIN_DIR="${VOODU_PLUGIN_DIR:-$(cd "$(dirname "$0")" && pwd)}"
PLUGIN_BIN="$PLUGIN_DIR/bin/voodu-redis"

log() { printf '[voodu-redis/uninstall] %s\n' "$*"; }

if [ "$(id -u)" -ne 0 ]; then
  log "must run as root"
  exit 1
fi

if [ -f "$PLUGIN_BIN" ]; then
  rm -f "$PLUGIN_BIN"
  log "removed $PLUGIN_BIN"
fi

log "any redis statefulsets the plugin spawned still live —"
log "use \`vd delete statefulset/<scope>/<name> --prune\` to wipe each one"
